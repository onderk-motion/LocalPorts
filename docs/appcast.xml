      <title>LocalPorts 2.0.1</title>
      <sparkle:releaseNotesLink>
        https://github.com/onderk-motion/LocalPorts/releases/tag/v2.0.1
      </sparkle:releaseNotesLink>
      <sparkle:fullReleaseNotesLink>
